# Copy to .env (gitignored) and fill in. docker compose reads this automatically.

# Your registered domain, with DNS hosted at Cloudflare. The app hostnames are
# subdomains with PUBLIC "DNS only" (grey-cloud) A records pointing at the
# Docker host's PRIVATE LAN IP — resolvable from anywhere, reachable only on
# your LAN. Real Let's Encrypt certs mean nothing to install on any device.
BASE_DOMAIN=example.com
BUDGET_HOST=budget.example.com
POCKET_ID_HOST=id.example.com

# Let's Encrypt registration email (cert expiry notices)
ACME_EMAIL=you@example.com

# Cloudflare API token for the DNS-01 challenge. Scope it to exactly:
# Zone > DNS > Edit, on the single zone above. Nothing more.
CLOUDFLARE_API_TOKEN=

# Pocket ID data encryption key — generate once: openssl rand -base64 32
POCKET_ID_ENCRYPTION_KEY=

# From Pocket ID admin UI → OIDC Clients → "Budget Dashboard"
# (create the client first — see docs/DEPLOY.md; secret is shown once)
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
